# ─────────────────────────────────────────
# LOCAL OVERRIDES TEMPLATE
# ─────────────────────────────────────────
# Copy this file to application-local.properties and fill in your values.
#
#   cp application-local.properties.example application-local.properties
#
# application-local.properties is gitignored — never commit it.
# Activate the local profile when running:
#
#   ./mvnw spring-boot:run -Dspring-boot.run.profiles=local

# ─────────────────────────────────────────
# DataSource
# ─────────────────────────────────────────
# H2 in-memory (default, no config needed):
#   Leave these commented out and remove ddl-auto override below.
#
# PostgreSQL example:
# spring.datasource.url=jdbc:postgresql://localhost:5432/daj2ee?sslmode=require&tcpKeepAlive=true
# spring.datasource.username=postgres
# spring.datasource.password=your-password
# spring.datasource.driver-class-name=org.postgresql.Driver
# spring.jpa.hibernate.ddl-auto=update
#
# HikariCP tuning for remote/cloud databases (Railway, Supabase, etc.)
# Without these, every request after an idle period pays a full SSL/TCP handshake cost (~2s).
# spring.datasource.hikari.minimum-idle=2
# spring.datasource.hikari.maximum-pool-size=10
# spring.datasource.hikari.keepalive-time=60000
# spring.datasource.hikari.idle-timeout=300000
# spring.datasource.hikari.max-lifetime=600000
# spring.datasource.hikari.connection-timeout=5000
# spring.datasource.hikari.connection-test-query=SELECT 1
#
# MySQL example:
# spring.datasource.url=jdbc:mysql://localhost:3306/daj2ee
# spring.datasource.username=root
# spring.datasource.password=your-password
# spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
# spring.jpa.hibernate.ddl-auto=update

# ─────────────────────────────────────────
# JWT
# ─────────────────────────────────────────
# Use a strong random value — minimum 32 characters recommended.
# Generate one with: openssl rand -hex 32
app.jwtSecret=replace-me-with-a-strong-random-secret
app.jwtExpirationMs=3600000

# ─────────────────────────────────────────
# Judge0
# ─────────────────────────────────────────
app.judge0.url=https://ce.judge0.com
# app.judge0.apiKey=your-api-key-if-required
