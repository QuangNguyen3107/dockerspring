# .env.example
#
# Copy this file to `.env` (in the project root) and fill in the values.
# The application will load variables from .env automatically (development).
#
# To load variables into your current shell session (Linux/macOS):
#   set -a; source .env; set +a
#
# Or use a tool such as direnv, or run the application using an env-loader that reads .env.
#
# NOTE: Do NOT commit your `.env` file. This project already ignores `.env` in .gitignore.

#####################
# Server
#####################
# Server port the app should listen on
SERVER_PORT=8080

#####################
# JWT / Authentication
#####################
# Secret used to sign JWT tokens (set a secure, random value for production)
APP_JWT_SECRET=changeit-secret-do-not-use-in-production

# Token lifetime in milliseconds (default: 1 hour)
APP_JWT_EXPIRATION_MS=3600000

#####################
# Judge0 (code execution engine)
#####################
# Judge0 host. Example: https://ce.judge0.com (CE instance) or your self-hosted Judge0 host
APP_JUDGE0_URL=https://ce.judge0.com

# Optional API key for your Judge0 host (if required by your host)
APP_JUDGE0_APIKEY=

# Polling settings used when waiting synchronously for Judge0 to finish execution
# Poll interval in milliseconds
APP_JUDGE0_POLL_INTERVAL_MS=500

# Maximum time to wait (milliseconds) when performing synchronous runs (default: 15s)
APP_JUDGE0_WAIT_TIMEOUT_MS=15000

# Scheduler settings for background poller (polls pending submissions and updates DB)
# Interval (ms) between poller runs
APP_JUDGE0_POLL_SCHEDULER_MS=2000

# Maximum number of pending submissions to process per poll run
APP_JUDGE0_POLL_SCHEDULER_MAX_PER_RUN=20

#####################
# Database (optional)
#####################
# Use these to point the app at an external DB (MySQL/Postgres).
# If not set, the app defaults to an in-memory H2 instance for development.
#
# Example MySQL:
# SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/daj2ee
# SPRING_DATASOURCE_USERNAME=root
# SPRING_DATASOURCE_PASSWORD=secret
# SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
#
# Example PostgreSQL:
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/daj2ee
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=secret
# SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
#
# JPA behavior (e.g., update/create)
# SPRING_JPA_HIBERNATE_DDL_AUTO=update

#####################
# Logging (optional)
#####################
#LOGGING_LEVEL_ORG_SPRINGFRAMEWORK=INFO
#LOGGING_LEVEL_COM_EXAMPLE=DEBUG

#####################
# Misc
#####################
# Active Spring profile (dev, prod, etc.)
#SPRING_PROFILES_ACTIVE=dev
